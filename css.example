   hanno sfondo bianco trasparente nel PNG, quindi ora 
   sono perfettamente leggibili su sfondo bianco.
   Il logo "Mystica Harmonia" ha testo rosso che su bianco si legge. */
.site-footer .gal-img img {
  max-width: 100%;
  height: auto;
}

/* Separatore opzionale tra le colonne */
.site-footer .row {
  align-items: flex-start;
}

/* ===============================================================
   HEADER — menu orizzontale su desktop, hamburger solo su mobile
   =============================================================== */

/* Desktop (≥ 992px): nascondi hamburger, mostra menu orizzontale */
@media (min-width: 992px) {
  
  /* Nascondi il pulsante hamburger */
  .masthead .navbar-toggler {
    display: none !important;
  }
  
  /* Forza il menu a essere visibile anche senza la classe .show */
  .masthead .main-navbar.collapse,
  .masthead .main-navbar.collapse:not(.show),
  .masthead #main-navigation-toggle {
    display: flex !important;
    flex-basis: auto !important;
    flex-grow: 1;
    justify-content: flex-end;
    align-items: center;
    gap: 1.5rem;
  }
  
  /* Lista dei link orizzontale */
  .masthead .main-navbar .navbar-nav {
    display: flex !important;
    flex-direction: row !important;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.5rem;
    align-items: center;
  }
  
  .masthead .main-navbar .navbar-nav > li {
    list-style: none;
    margin: 0;
  }
  
  /* Stile dei link del menu */
  .masthead .main-navbar .navbar-nav > li > a {
    color: #ffffff !important;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    padding: 0.5rem 1rem;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    border-radius: 0;
  }
  
  .masthead .main-navbar .navbar-nav > li > a:hover,
  .masthead .main-navbar .navbar-nav > li > a:focus {
    color: #ffffff !important;
    background: rgba(255, 255, 255, 0.15);
    text-decoration: none;
  }
  
  /* Search box nell'header su desktop */
  .masthead .site-search {
    display: flex !important;
    align-items: center;
    margin-left: 1rem;
  }
  
  .masthead .site-search input[type="text"] {
    background: #ffffff;
    color: #000000;
    border: none;
    height: 38px;
    padding: 0 0.75rem;
    min-width: 180px;
    border-radius: 3px 0 0 3px;
  }
  
  .masthead .site-search .btn {
    background: #ffffff !important;
    color: #0066cc !important;
    border: none;
    border-left: 9px solid #ffffff;
    height: 38px;
    width: 38px;
    padding: 0;
    border-radius: 0 3px 3px 0;
    box-shadow: none;
  }
  
  .masthead .site-search .btn i {
    color: #0066cc !important;
  }
}

/* Mobile (< 992px): hamburger visibile, menu nascosto quando collapsed */
@media (max-width: 991px) {
  .masthead .navbar-toggler {
    display: block;
    background: transparent;
    border: 1px solid #ffffff;
    color: #ffffff;
  }
}

.homepage [role="main"] {
  border-top: 0px solid rgb(204, 204, 204);
 background-size: contain;
 background-position: right center;
 background-repeat: no-repeat;
}

.homepage {

background:url(../../base/images/IMMAGINEDIFONDO) no-repeat center center fixed;
 -webkit-background-size: cover;
    -moz-background-size: cover;
    -o-background-size: cover;
    background-size: cover;

}
/* Link di default: blu istituzionale leggibile su sfondo bianco */
a {
  color: #0066cc;
}

a:hover {
  color: #003d7a;
  text-decoration: underline;
}

/* Link bianchi SOLO nell'header del sito */
.masthead a,
.account-masthead a {
  color: #ffffff;
}

.masthead a:hover,
.account-masthead a:hover {
  color: #ffffff;
}

/* Heading delle risorse e breadcrumb: colore blu (non bianco su bianco) */
.resource-item .heading,
.breadcrumb {
  color: #003d7a;
}
.homepage [role="main"] {
    border-top: 0px solid rgb(204, 204, 204);
    padding-bottom: 30px;
    background-image: none;
}
