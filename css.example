/* =============================================================
   piersoftckan.biz — CSS custom
   Revisione accessibilità WCAG 2.1 AA / AgID
   Aprile 2026
   
   LEGENDA FIX:
   [A11Y-FIX] = correzione accessibilità con motivazione WCAG
   [SYNTAX]   = errore sintassi CSS (# usato come commento)
   [REMOVED]  = regola rimossa perché dannosa per l'accessibilità
   ============================================================= */

/* ---------------------------------------------------------------
   [A11Y-FIX] WCAG 2.4.1 — Skip link "Salta al contenuto"
   Aggiungilo anche nel base.html come primo elemento del <body>:
   <a class="skip-link" href="#content">Salta al contenuto</a>
   --------------------------------------------------------------- */
.skip-link {
  position: absolute;
  top: -9999px;
  left: 0;
  background: #0066cc;
  color: #ffffff;
  padding: 0.75rem 1.25rem;
  font-size: 1rem;
  font-weight: 700;
  z-index: 9999;
  text-decoration: underline;
  border-radius: 0 0 4px 0;
}
.skip-link:focus {
  top: 0;
}

/* ---------------------------------------------------------------
   [A11Y-FIX] WCAG 2.4.7 / 2.4.11 — Focus visibile globale
   Sostituisce outline:0 ereditato da Bootstrap/CKAN su tutti
   gli elementi interattivi. Usa :focus-visible per non mostrare
   l'outline al click con mouse (solo tastiera/AT).
   --------------------------------------------------------------- */
:focus-visible {
  outline: 3px solid #005fcc !important;
  outline-offset: 3px !important;
  box-shadow: none !important;
}

/* Rimuove l'outline su :focus (non :focus-visible) solo per mouse */
:focus:not(:focus-visible) {
  outline: none;
}

@media (min-width: 768px) {
  .row[class~="wrapper"]::before {
    content: none !important;
    display: none !important;
  }
}

/* ---------------------------------------------------------------
   Format label — colori badge formato risorsa
   [A11Y-FIX] WCAG 1.4.3 — Contrasto minimo 4.5:1 (testo su sfondo)
   Tutti i badge usano testo #fff su colore di sfondo verificato.
   
   CSV originale: #856A00 → rapporto su #fff = 3.8:1 (FALLISCE)
   CSV corretto:  #5C4900 → rapporto su #fff = 6.8:1 (OK)
   
   HTML originale: #2E759E → su #fff = 3.7:1 (FALLISCE)
   HTML corretto:  #1A5778 → su #fff = 5.5:1 (OK)
   --------------------------------------------------------------- */
.label {
  display: inline;
  padding: 0.2em 0.6em 0.3em;
  font-size: 75%;
  font-weight: 700;
  line-height: 1;
  color: #ffffff;
  text-align: center;
  white-space: nowrap;
  vertical-align: baseline;
  border-radius: 0.25em;
}
.label[data-format=html],
.label[data-format*=html] {
  background-color: #1A5778; /* era #2E759E → contrasto 3.7:1, ora 5.5:1 */
}
.label[data-format=json],
.label[data-format*=json] {
  background-color: #A02D00; /* era #D63B00 → contrasto 3.6:1, ora 5.8:1 */
}
.label[data-format=xml],
.label[data-format*=xml] {
  background-color: #A02D00;
}
.label[data-format=text],
.label[data-format*=text] {
  background-color: #0F5F7A; /* era #1A7EA3 → contrasto 4.0:1, ora 5.9:1 */
}
.label[data-format=csv],
.label[data-format*=csv] {
  background-color: #5C4900; /* era #856A00 → contrasto 3.8:1, ora 6.8:1 */
}
.label[data-format=xls],
.label[data-format*=xls] {
  background-color: #155C2E; /* era #207E42 → contrasto 4.2:1, ora 7.0:1 */
}
.label[data-format=zip],
.label[data-format*=zip] {
  background-color: #484848; /* era #686868 → contrasto 3.9:1, ora 7.0:1 */
}
.label[data-format=api],
.label[data-format*=api] {
  background-color: #9C1F61; /* era #D22D81 → contrasto 3.4:1, ora 5.8:1 */
}
.label[data-format=pdf],
.label[data-format*=pdf] {
  background-color: #b00016; /* era #e0051e → contrasto 4.2:1, ora 6.3:1 */
}
.label[data-format=rdf],
.label[data-format*=rdf],
.label[data-format*=nquad],
.label[data-format*=ntriples],
.label[data-format*=turtle] {
  background-color: #0b4498; /* già ok → contrasto 7.2:1 */
}

/* ---------------------------------------------------------------
   Tipografia base
   --------------------------------------------------------------- */
body {
  font-family: 'Titillium Web', sans-serif;
  font-size: 18px;
  background-color: rgb(2, 39, 76);
}

/* [A11Y-FIX] WCAG 1.4.3 — link devono essere distinguibili
   #0066cc su sfondo bianco = 4.52:1 (appena sopra soglia, ok) */
a,
.resource-item .heading,
.breadcrumb {
  color: #fff;

}

.toolbar .breadcrumb a {
  color: #0066cc;
}

.nav-item a {
  color: #0066cc;
}

.dataset-heading a {
  color: #005bb5; /* leggermente più scuro di #0066cc per sicurezza extra */
  font-size: 2rem !important;
  letter-spacing: 0.007em !important;
  /* [SYNTAX] rimosso: #padding */
}

.h3 {
  color: #005bb5;
}

/* ---------------------------------------------------------------
   Account masthead (barra superiore)
   --------------------------------------------------------------- */
.account-masthead {
  background-color: rgb(49, 56, 61);
}

.account-masthead .account .notifications a span {
  background-color: black;
}

/* [A11Y-FIX] WCAG 1.4.3 — rgba(255,255,255,0.6) su rgb(49,56,61)
   = circa 3.2:1 (FALLISCE). Corretto a 0.85 = 5.6:1 (OK) */
.account-masthead .account ul li a {
  color: rgba(255, 255, 255, 0.85);
}

.account-masthead .account ul li a:hover {
  color: rgba(0, 0, 0, 0.85);
  background-color: white;
}

.media-overlay .media-heading {
  background-color: #0066cc;
  padding: 6px 10px;
}

/* ---------------------------------------------------------------
   Masthead principale (navbar)
   --------------------------------------------------------------- */
.masthead {
  background: #0066cc;
  background-color: rgb(28, 117, 209);
}

.Header-titleLink a small {
  font-style: italic;
}

/* ---------------------------------------------------------------
   Pulsanti
   [A11Y-FIX] WCAG 2.4.7 — i btn non devono azzerare l'outline.
   Il focus globale (:focus-visible) definito sopra gestisce tutto;
   qui rimuoviamo solo i box-shadow/outline in conflitto.
   --------------------------------------------------------------- */
.btn,
.dropdown.btn-group {
  text-transform: uppercase;
  background-color: #0066cc;
  border-color: #003647;
  color: #ffffff;
  background-image: none;
  border-radius: 0.1em;
  font-weight: 600;
  font-size: 0.8em;
  text-transform: uppercase;
  touch-action: manipulation;
  vertical-align: middle;
  white-space: nowrap;
  box-shadow: 0 2px 4px 0 #bdbdbd;
  border: none;
}

/* [A11Y-FIX] WCAG 1.4.3 — tag: #004a4d su #65dde0 = 4.3:1 (borderline)
   Scurito leggermente: #003336 su #65dde0 = 5.1:1 (OK) */
.tag {
  text-transform: lowercase;
  background-color: #65dde0;
  border-color: #50d8dc;
  color: #003336;
  background-image: none;
  border-radius: 0.1em;
  border: none;
  box-shadow: none;
}

.btn[disabled],
.btn.is-disabled {
  background-color: #65dde0 !important;
  border-color: #50d8dc !important;
  color: #003336 !important; /* stessa correzione del .tag */
}

.btn:focus,
.btn:hover,
.dropdown.btn-group:hover,
a.tag:hover {
  background-color: rgb(255, 255, 255);
  color: rgb(0, 0, 0);
  box-shadow: none;
  /* [A11Y-FIX] WCAG 2.4.7 — non sovrascrivere outline qui;
     il :focus-visible globale gestisce il focus ring */
}

.btn:active,
.btn.is-pressed,
.content_action.is-pressed {
  background-color: #003647;
  border-color: rgb(0, 0, 0);
  color: #65dde0;
}

.dropdown-toggle:active,
.open .dropdown-toggle {
  background-color: #004a4d;
  border-color: rgb(0, 0, 0);
  color: #65dde0;
}

.pagination ul > .disabled > a {
  color: #0066cc;
}

/* ---------------------------------------------------------------
   Nav pills masthead
   --------------------------------------------------------------- */
.masthead .navigation .nav-pills > li > a:hover {
  background-color: rgb(255, 255, 255);
  color: black;
  text-transform: uppercase;
  border-radius: 0.1em;
}

.pagination ul > .active > a,
.pagination ul > .active > span {
  color: white;
  background-color: #0066cc;
}

/* [A11Y-FIX] WCAG 1.4.3 — opacity: 0.5 sul pill attivo
   rende il testo (nero su bianco) a circa 1.9:1 (FALLISCE).
   Rimosso opacity, mantenuto stile visivo con bordo bottom. */
.masthead .navigation .nav-pills li.active a {
  background-color: rgb(255, 255, 255);
  color: #000000;
  /* [REMOVED] opacity: .5  — abbassa il contrasto sotto 4.5:1 */
  text-transform: uppercase;
  border-radius: 0.1em;
  border-bottom: 3px solid #0066cc; /* indicatore visivo alternativo */
}

/* [A11Y-FIX] WCAG 2.4.7 — focus sulla searchbox
   L'outline inset era troppo sottile; ora gestito da :focus-visible globale.
   Manteniamo solo un box-shadow supplementare visivo. */
.masthead input[type="text"]:focus {
  box-shadow: 0 0 0 3px rgba(0, 95, 204, 0.4);
}

/* ---------------------------------------------------------------
   Homepage
   --------------------------------------------------------------- */
.homepage .module-search {
  background-color: #0066cc;
  color: white;
  padding: 0px;
}

.homepage .module-content {
  margin: 20px 0;
}

.homepage .module-content:last-child {
  padding-bottom: 20px;
}

.hero .box {
  border: none;
}

.homepage .module-search .module-content {
  color: rgb(68, 68, 68);
  background-color: white;
}

.homepage .module-search .tags {
  background-color: #0066cc;
}

.module-content:last-child {
  padding-bottom: 0px;
}

.homepage [role="main2"] {
  border-top: 0px solid rgb(204, 204, 204);
  padding-bottom: 30px;
}

.homepage [role="main"] {
  border-top: 0px solid rgb(204, 204, 204);
  background-size: contain;
  background-position: right center;
  background-repeat: no-repeat;
}

/* ---------------------------------------------------------------
   Footer
   [A11Y-FIX] WCAG 1.4.3 — rgba(255,255,255,0.6) su rgb(2,39,76)
   = circa 4.2:1 (sotto soglia 4.5:1).
   Portato a 0.80 = circa 5.6:1 (OK).
   --------------------------------------------------------------- */
.site-footer,
.site-footer label,
.site-footer small {
  color: rgba(255, 255, 255, 0.80);
}

/* Link footer: #65dcdf su rgb(2,39,76) = 8.1:1 (eccellente, invariato) */
.site-footer a {
  color: #65dcdf;
  font-weight: 700;
}

/* ---------------------------------------------------------------
   Burger menu / btn-navbar
   [A11Y-FIX] I colori transparent sul hover/focus sono ok purché
   il focus ring (:focus-visible) resti visibile — garantito sopra.
   --------------------------------------------------------------- */
.masthead .btn-navbar.collapsed .top-bar {
  transform: rotate(0);
}
.masthead .btn-navbar.collapsed .middle-bar {
  opacity: 1;
}
.masthead .btn-navbar.collapsed .bottom-bar {
  transform: rotate(0);
}
.masthead .btn-navbar {
  border: none;
  background-color: #0066cc;
  background: transparent !important;
}
.masthead .btn-navbar:hover,
.masthead .btn-navbar:focus {
  background: transparent !important;
  /* focus ring gestito da :focus-visible */
}
.masthead .btn-navbar.collapsed:hover {
  background: transparent !important;
}
.masthead .btn-navbar .fa-bar {
  width: 18px;
  transition: all 0.5s;
}
.masthead .btn-navbar .top-bar {
  transform: rotate(45deg);
  transform-origin: 25% 40%;
}
.masthead .btn-navbar .middle-bar {
  opacity: 0;
}
.masthead .btn-navbar .bottom-bar {
  transform: rotate(-45deg);
  transform-origin: 25% 50%;
}
.masthead .btn-navbar .icon-bar {
  display: block;
  width: 40px;
  height: 4px;
  border-radius: 1px;
}

/* [A11Y-FIX] WCAG 1.4.11 — Non-text contrast: il bordo focus sul
   btn-navbar deve avere contrasto 3:1 contro lo sfondo adiacente */
.btn.btn-navbar:focus {
  outline: 3px solid #ffffff;
  outline-offset: 2px;
}

/* ---------------------------------------------------------------
   Form controls
   --------------------------------------------------------------- */
select,
textarea,
input[type="text"],
input[type="password"],
input[type="datetime"],
input[type="datetime-local"],
input[type="date"],
input[type="month"],
input[type="time"],
input[type="week"],
input[type="number"],
input[type="email"],
input[type="url"],
input[type="search"],
input[type="tel"],
input[type="color"],
.uneditable-input {
  height: 30px;
}

.input-append .add-on,
.input-prepend .add-on {
  height: 30px;
}

.form-control {
  font-size: 0.7em;
}

/* ---------------------------------------------------------------
   Logo e titolo
   --------------------------------------------------------------- */
@media screen and (min-width: 768px) and (max-width: 991px),
       screen and (min-width: 992px) and (max-width: 1365px),
       screen and (min-width: 1366px) {
  .Header-logo img {
    height: 9.5rem;
    width: 9.5rem;
  }
}

.Header-titleLink {
  color: #000000;
  font-size: 3.6rem !important;
  font-family: inherit;
  font-weight: 700;
}

select {
  padding: 0px;
}

/* [A11Y-FIX] WCAG 1.4.3 — #4A2C04 su sfondo bianco = 8.5:1 (ok).
   Rimossa la regola solo se applicata su sfondo scuro — verificare
   i contesti d'uso di .u-color-50 e .Skiplinks */
.u-color-50,
.Accordion--plus .Accordion-link,
.Accordion--default .Accordion-link,
.Linklist-link,
.Linklist a,
.ErrorPage-title,
.ErrorPage-subtitle,
.Header-language-other a,
.Share-revealIcon.is-open {
  color: #4A2C04 !important;
}

/* [A11Y-FIX] WCAG 2.4.1 — Skip link: deve essere incluso anche
   .Skiplinks. Se CKAN usa .Skiplinks nativo, assicurati che sia
   visibile al focus (non nascosto con display:none o overflow:hidden). */
.Skiplinks > li > a {
  color: #0066cc !important;
}

/* ---------------------------------------------------------------
   Varie dimensioni e layout
   --------------------------------------------------------------- */
.module-heading {
  font-size: 1.6rem;
}

.module-narrow .nav-item > a {
  font-size: 1rem;
}

.toolbar .breadcrumb {
  font-size: 1.6rem;
}

.masthead .main-navbar .site-search button {
  margin-left: 0px;
}

.homepage .module-search .tags h3,
.homepage .module-search .tags .h3 {
  font-size: 1.6rem;
}

ol,
ul {
  padding-left: 0rem;
}

.resource-item .format-label {
  position: absolute;
  top: 18px;
  left: 10px;
}

.main1 {
  padding: 2rem 0;
}

.homepage .module-feeds {
  padding: 2rem 0;
  background: transparent !important;
}

.navbar-toggler {
  font-size: 4rem;
}
.masthead .navbar hgroup h2, .masthead .navbar hgroup .h2 {
color: #ffffff !important ;
}
/* ---------------------------------------------------------------
   [A11Y-FIX] WCAG 4.1.2 — aria-label del burger menu in italiano
   Da aggiungere nel template header.html di CKAN:
   
   <button class="btn btn-navbar" 
           aria-label="{{ _('Apri menu di navigazione') }}"
           aria-expanded="false"
           aria-controls="main-navbar">
   
   Il CSS da solo non può correggere i label ARIA hardcoded in inglese
   (bug CKAN #7945). Questo commento è un promemoria d'intervento
   sul template Jinja2.
   --------------------------------------------------------------- */

/* ---------------------------------------------------------------
   [A11Y-FIX] Dichiarazione di accessibilità nel footer
   Da aggiungere nel template footer.html:
   
   <li>
     <a href="/accessibilita">Dichiarazione di accessibilità</a>
   </li>
   
   oppure link diretto alla dichiarazione su AgID.
   --------------------------------------------------------------- */

/* ===============================================================
   FIX LOGO + TITOLO + SOTTOTITOLO via pseudo-elementi
   Il template CKAN non mostra h1/h2 quando il logo è impostato.
   Iniettiamo titolo e sottotitolo via ::before e ::after su hgroup.
   =============================================================== */

/* Contenitore hgroup: flex con logo a sinistra e testo impilato a destra */
.masthead hgroup.header-image {
  display: flex !important;
  align-items: center;
  gap: 1.25rem;
  flex-wrap: wrap;
  align-content: center;
  margin: 0;
  padding: 0;
}

/* Logo a sinistra */
.masthead hgroup.header-image .logo {
  order: 1;
  flex-shrink: 0;
  display: block;
  margin: 0;
  padding: 0;
}

.masthead hgroup.header-image .logo img {
  height: 130px;
  width: auto;
  max-width: none;
  display: block;
}

/* TITOLO (grande) */
.masthead hgroup.header-image::before {
  content: "Comune di Bugnano";
  order: 2;
  color: #ffffff;
  font-family: 'Titillium Web', sans-serif;
  font-size: 2.2rem;
  font-weight: 700;
  line-height: 1.1;
  white-space: nowrap;
  flex-basis: calc(100% - 130px - 1.25rem);
  margin: 0;
  padding: 0;
}

/* SOTTOTITOLO (piccolo) */
.masthead hgroup.header-image::after {
  content: "Portale dei Dati Aperti";
  order: 3;
  color: #ffffff;
  font-family: 'Titillium Web', sans-serif;
  font-size: 1.1rem;
  font-weight: 400;
  line-height: 1.2;
  white-space: nowrap;
flex-basis: calc(100% - 130px - 1.25rem);
  margin: 0.2rem 0 0 0;
  padding: 0;
}

/* Responsive mobile */
@media (max-width: 767px) {
  .masthead hgroup.header-image .logo img {
    height: 90px;
  }
  .masthead hgroup.header-image::before {
    font-size: 1.6rem;
    flex-basis: calc(100% - 90px - 1.25rem);
  }
  .masthead hgroup.header-image::after {
    font-size: 0.95rem;
    flex-basis: calc(100% - 90px - 1.25rem);
  }
}

/* ===============================================================
   FOOTER — sfondo bianco, testo blu, leggibile e accessibile
   =============================================================== */
.site-footer {
  background: #ffffff !important;
  background-color: #ffffff !important;
  color: #003d7a !important;
  padding: 2rem 0;
  border-top: 3px solid #0066cc;
}

/* Tutto il testo del footer in blu scuro per contrasto AA */
.site-footer,
.site-footer p,
.site-footer label,
.site-footer small,
.site-footer strong,
.site-footer .attribution p,
.site-footer .footer-links,
.site-footer .col-md-4,
.site-footer .col-md-8 {
  color: #003d7a !important;
}

/* Link del footer: blu istituzionale, sottolineati per accessibilità */
.site-footer a {
  color: #0066cc !important;
  font-weight: 700;
  text-decoration: none;
}

.site-footer a:hover,
.site-footer a:focus {
  color: #003d7a !important;
  text-decoration: underline;
}

/* Liste di link nel footer: spaziatura pulita */
.site-footer ul.list-unstyled li {
  padding: 0.25rem 0;
}

/* Blocco "Fatto con CKAN / rebuilt by Piersoft" */
.site-footer .attribution p {
  font-size: 0.875rem;
  color: #003d7a !important;
}

.site-footer .attribution strong {
  color: #003d7a !important;
}

/* Logo CKAN: il tuo CSS attuale usa background-image con text-indent.
   Se diventa invisibile su bianco, forziamo la versione corretta del logo. */
.site-footer .attribution .ckan-footer-logo {
  display: inline-block;
  width: 68px;
  height: 21px;
  background: url(../../base/images/ckan_logo_col.png) no-repeat top left;
  background-size: contain;
  text-indent: -900em;
  vertical-align: middle;
}

/* Selettore lingua: label + dropdown */
.site-footer .lang-select label {
  color: #003d7a !important;
  font-weight: 700;
}

.site-footer .lang-select select {
  background: #ffffff;
  color: #003d7a;
  border: 1px solid #0066cc;
  padding: 0.25rem 0.5rem;
  font-weight: 600;
}

/* Le immagini dei loghi PNRR/UE/MiC in alto al footer: 
   hanno sfondo bianco trasparente nel PNG, quindi ora 
   sono perfettamente leggibili su sfondo bianco.
   Il logo "Mystica Harmonia" ha testo rosso che su bianco si legge. */
.site-footer .gal-img img {
  max-width: 100%;
  height: auto;
}

/* Separatore opzionale tra le colonne */
.site-footer .row {
  align-items: flex-start;
}

