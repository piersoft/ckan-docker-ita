# =====================================================================
#  CKAN Docker per l'Italia — file di configurazione (DEMO)
#  Copiare in `.env` e modificare SOLO il blocco "DA MODIFICARE".
#  Tutto il resto ha default sensati per un test locale.
# =====================================================================

# ---------------------------------------------------------------------
#  >>> DA MODIFICARE <<<
# ---------------------------------------------------------------------
# URL pubblico del portale. NIENTE slash finale.
#   - Test locale via NGINX in HTTP : http://localhost:8080
#   - Test locale via NGINX in HTTPS: https://localhost:8443
#   - IP privato                    : http://192.168.1.50:8080
#   - Produzione                    : https://dati.miocomune.it
# Da questo valore vengono derivati automaticamente, a runtime:
#   ckanext.dcat.base_uri  e  ckan.oaipmh.base_url (vedi sotto).
CKAN_SITE_URL=http://localhost:8080

# Password del primo amministratore (l'utente e' CKAN_SYSADMIN_NAME).
CKAN_SYSADMIN_NAME=ckan_admin
CKAN_SYSADMIN_PASSWORD=CHANGE_ME_admin_pwd
CKAN_SYSADMIN_EMAIL=admin@example.com

# Segreti applicativi. In locale lasciare pure CHANGE_ME; in produzione
# generarli con:  python3 -c "import secrets; print(secrets.token_urlsafe())"
CKAN___BEAKER__SESSION__SECRET=CHANGE_ME
CKAN___API_TOKEN__JWT__ENCODE__SECRET=string:CHANGE_ME
CKAN___API_TOKEN__JWT__DECODE__SECRET=string:CHANGE_ME

# Username GeoNames per il geocoding spaziale (default: demo, limitato).
GEONAMES_USERNAME=demo

# ---------------------------------------------------------------------
#  Porte pubblicate sull'host  (host:container)
# ---------------------------------------------------------------------
# Accesso NON-SSL  -> http://<host>:${NGINX_PORT_HOST}
NGINX_PORT_HOST=8080
# Accesso SSL      -> https://<host>:${NGINX_SSLPORT_HOST}  (cert self-signed)
NGINX_SSLPORT_HOST=8443
# Porte interne dei container nginx (non cambiare salvo necessita')
NGINX_PORT=80
NGINX_SSLPORT=443
# Accesso diretto a CKAN bypassando NGINX (utile in debug). Vedi docker-compose.
CKAN_PORT=5000
CKAN_PORT_HOST=5000

# ---------------------------------------------------------------------
#  Nomi dei container
# ---------------------------------------------------------------------
NGINX_CONTAINER_NAME=nginx
REDIS_CONTAINER_NAME=redis
POSTGRESQL_CONTAINER_NAME=db
SOLR_CONTAINER_NAME=solr
CKAN_CONTAINER_NAME=ckan
WORKER_CONTAINER_NAME=ckan-worker

# ---------------------------------------------------------------------
#  Database PostgreSQL  (PG16 -> richiede ?sslmode=disable negli URL)
# ---------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=db
CKAN_DB_USER=ckandbuser
CKAN_DB_PASSWORD=ckandbpassword
CKAN_DB=ckandb
DATASTORE_READONLY_USER=datastore_ro
DATASTORE_READONLY_PASSWORD=datastore
DATASTORE_DB=datastore

CKAN_SQLALCHEMY_URL=postgresql://ckandbuser:ckandbpassword@db/ckandb?sslmode=disable
CKAN_DATASTORE_WRITE_URL=postgresql://ckandbuser:ckandbpassword@db/datastore?sslmode=disable
CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:datastore@db/datastore?sslmode=disable

# Database di test (usati solo dai test automatici)
TEST_CKAN_SQLALCHEMY_URL=postgresql://ckandbuser:ckandbpassword@db/ckan_test?sslmode=disable
TEST_CKAN_DATASTORE_WRITE_URL=postgresql://ckandbuser:ckandbpassword@db/datastore_test?sslmode=disable
TEST_CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:datastore@db/datastore_test?sslmode=disable

# ---------------------------------------------------------------------
#  CKAN core
# ---------------------------------------------------------------------
CKAN_VERSION=2.10.9
CKAN_SITE_ID=default
CKAN_STORAGE_PATH=/var/lib/ckan
CKAN_LOCALE_DEFAULT=it
TZ=Europe/Rome

# DCAT: base_uri e profili. base_uri viene comunque riallineato a
# CKAN_SITE_URL a runtime dallo script 02_ckan-init.sh.
CKANEXT__DCAT__BASE__URI=http://localhost:8080
CKANEXT__DCAT__RDF__PROFILES=euro_dcat_ap_2 it_dcat_ap

# OAI-PMH: se vuoto viene usato ${CKAN_SITE_URL}/oai (vedi 01_setup_xloader.sh)
CKAN_OAIPMH_BASE_URL=
CKANEXT__OAI_PMH_SERVER__RESUMPTION_TOKEN_BATCH_SIZE=1024
CKANEXT__OAI_PMH_SERVER__RESUMPTION_TOKEN_VALIDITY=36000000

# Datapusher / Xloader token header
CKAN_DATAPUSHER_API_TOKEN=X-CKAN-API-Key

# SMTP (opzionale, per le email)
CKAN_SMTP_SERVER=smtp.corporateict.domain:25
CKAN_SMTP_STARTTLS=True
CKAN_SMTP_USER=user
CKAN_SMTP_PASSWORD=pass
CKAN_SMTP_MAIL_FROM=ckan@localhost

# ---------------------------------------------------------------------
#  Solr / Redis
# ---------------------------------------------------------------------
SOLR_IMAGE_VERSION=2.10-solr9
CKAN_SOLR_URL=http://solr:8983/solr/ckan
TEST_CKAN_SOLR_URL=http://solr:8983/solr/ckan
REDIS_VERSION=6
CKAN_REDIS_URL=redis://redis:6379/1
TEST_CKAN_REDIS_URL=redis://redis:6379/1

# ---------------------------------------------------------------------
#  Estensioni abilitate (DCAT-AP_IT, OAI-PMH, harvest, LOD/RDF, MQA)
#  Per disattivare l'integrazione OpenAIRE/MQA rimuovere dcat_ap_edp_mqa
#  qui e in 02_ckan-init.sh (ckanext.dcat.rdf.profiles).
# ---------------------------------------------------------------------
CKAN__PLUGINS=envvars datatables_view image_view text_view recline_view datastore xloader harvest ckan_harvester dcat dcat_rdf_harvester dcat_json_harvester dcat_json_interface structured_data dcatapit_pkg dcatapit_org dcatapit_config dcatapit_theme_group_mapper multilang dcat_ap_edp_mqa oai_pmh_server
CKAN__HARVEST__MQ__TYPE=redis
CKAN__HARVEST__MQ__HOSTNAME=redis
CKAN__HARVEST__MQ__PORT=6379
CKAN__HARVEST__MQ__REDIS_DB=1

# ---------------------------------------------------------------------
#  uWSGI: timeout estesi per la generazione di catalog.rdf/ttl grandi
# ---------------------------------------------------------------------
UWSGI_HARAKIRI=500
EXTRA_UWSGI_OPTS=--http-timeout 600 --socket-timeout 600 --ignore-sigpipe --ignore-write-errors --disable-write-exception

# Dev
USE_HTTPS_FOR_DEV=false
